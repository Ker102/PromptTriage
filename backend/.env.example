# =============================================
# PromptTriage Backend — Environment Variables
# =============================================
# Copy this file to `.env` and fill in your values.

# ── Required: Google AI ──────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Required: Pinecone Vector Store ──────────
# Get from Pinecone console: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=prompttriage-prompts
PINECONE_ENVIRONMENT=us-east-1

# ── Optional: Frontend URL (CORS) ───────────
FRONTEND_URL=http://localhost:3000

# ── Embedding Settings (defaults shown) ──────
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIMENSIONS=768
