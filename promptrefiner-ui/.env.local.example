# =============================================
# PromptTriage Frontend — Environment Variables
# =============================================
# Copy this file to `.env.local` and fill in your values.

# ── Required: Google AI (Gemini) ─────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Required: Authentication ─────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── Required: RAG Backend ────────────────────
RAG_API_URL=http://localhost:8080

# ── Optional: Dev Bypass ─────────────────────
# Set to "true" to bypass auth on localhost (development only)
# ALLOW_DEV_BYPASS=true
# NEXT_PUBLIC_DEV_SUPERUSER=true

# ── Optional: Firecrawl (web search) ─────────
# FIRECRAWL_API_KEY=your_firecrawl_api_key

# ── Optional: Error Feedback Webhook ─────────
# FEEDBACK_WEBHOOK_URL=https://your-webhook-url.com/endpoint
