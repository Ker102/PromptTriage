# =============================================
# PromptTriage Frontend — Environment Variables
# =============================================
# Copy this file to `.env.local` and fill in your values.

# ── Required: Google AI (Gemini) ─────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Required: Supabase ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Required: RAG Backend ────────────────────
RAG_API_URL=http://localhost:8080

# ── Optional: Dev Bypass ─────────────────────
# Set to "true" to bypass auth on localhost (development only)
# ALLOW_DEV_BYPASS=true
# NEXT_PUBLIC_DEV_SUPERUSER=true

# ── Optional: Firecrawl (web search) ─────────
# FIRECRAWL_API_KEY=your_firecrawl_api_key

# ── Optional: Error Feedback Webhook ─────────
# FEEDBACK_WEBHOOK_URL=https://your-webhook-url.com/endpoint

# ── Stripe Payments ──────────────────────────
STRIPE_SECRET_KEY=sk_test_... 
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
# NEXT_PUBLIC_APP_URL=https://your-domain.com
